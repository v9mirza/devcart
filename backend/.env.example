# Copy to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=5000

# Allowed frontend origins (comma-separated). Defaults to http://localhost:5173 if unset.
# FRONTEND_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/devcart

# User auth (JWT)
JWT_SECRET=change_me_use_a_long_random_string

# Admin panel (/admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
SESSION_SECRET=change_me_use_a_long_random_string
